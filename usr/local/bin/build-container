if not hasattr(__builtins__, "frozendict"):
    frozendict = MappingProxyType


class _ProtocolCheck(type(Protocol)):
    @override
    def __instancecheck__(cls, instance: object) -> bool:
        if (hook := getattr(cls, "__instancehook__", None)) is not None:
            return hook(instance)
        else:
            return super().__instancecheck__(instance)


@runtime_checkable
class MacroFunction(Protocol, metaclass=_ProtocolCheck):
    """A protocol for macro functions."""

    __name__: str

    def __call__(self, body: str, **options: str) -> str:
        """Called when a macro is expanded.

        Arguments:
            body: The body (parameter) of the macro.
            **options: Any extra options for the macro.

        Returns:
            What the macro should be replaced with.
        """
        ...

    @classmethod
    def __instancehook__(cls, instance: Any) -> bool:  # noqa: PLW3201
        try:
            return all((
                callable(instance),
                isinstance(instance.__name__, str),
                not instance.__name__.startswith("_"),
                get_annotations(instance)["body"] is str,
                get_annotations(instance)["return"] is str,
            ))
        except Exception:
            return False


@runtime_checkable
class _BuildContextFunction(Protocol):
    """A protocol for functions that add a build context."""

    def __call__(
        self, path: Path, name: str | None = None
    ) -> tuple[str, Path]: ...


class CmdlineOptionBase(ABC):
    """A command-line option."""

    cmdline_key: ClassVar[str] | str
    """The name of the option (example: `--file`)."""

    @property
    @abstractmethod
    def cmdline_value(self) -> str | None:
        """The value of the option (example: `Containerfile`)."""
        ...

    separator: str = "="
    """The separator to use between the key and value (default: `=`)."""

    @final
    @override
    def __eq__(self, other: object) -> bool:
        if not isinstance(other, CmdlineOptionBase):
            return NotImplemented
        return (self.cmdline_key, self.cmdline_value) == (
            other.cmdline_key,
            other.cmdline_value,
        )

    @final
    @override
    def __hash__(self) -> int:
        return hash((self.cmdline_key, self.cmdline_value))

    @final
    @override
    def __str__(self) -> str:
        out = f"--{self.cmdline_key}"
        if self.cmdline_value is not None:
            out += f"{self.separator}{self.cmdline_value}"
        return out

    @overload
    @staticmethod
    def convert(*options: CmdlineOptionBase) -> Iterator[str]: ...

    @overload
    @staticmethod
    def convert(
        option: Iterable[CmdlineOptionBase | str], /
    ) -> Iterator[str]: ...

    @final
    @staticmethod
    def convert(
        *args: CmdlineOptionBase | Iterable[CmdlineOptionBase | str],
    ) -> Iterator[str]:
        """Converts a list of command-line options to strings."""

        options: Iterable[CmdlineOptionBase | str]
        if len(args) == 1 and isinstance(args[0], Iterable):
            options = args[0]
        else:
            options = cast(Iterable[CmdlineOptionBase | str], args)

        return map(str, options)


@enum_unique
class _UpdateFrequency(StrEnum):
    daily = "daily"
    weekly = "weekly"
    biweekly = "biweekly"
    monthly = "monthly"
    quarterly = "quarterly"


###################
### Dataclasses ###
###################


@dataclass(kw_only=False, slots=True, frozen=True, eq=True)
class CmdlineOption(CmdlineOptionBase):
    """A command-line option."""

    cmdline_key: str
    """The name of the option (example: `--file`)."""

    cmdline_value: str | None = None  # pyright: ignore[reportIncompatibleMethodOverride]
    """The value of the option (example: `Containerfile`)."""


@final
@dataclass(kw_only=True, slots=True, frozen=True)
class _RunMountOption(CmdlineOptionBase):
    """The `--mount` option for a `RUN` command."""

    from_: tuple[str, Path] | None
    """The build context to mount from (optional)."""

    type: Literal["bind"] = "bind"
    """The type of the mount (default: `bind`)."""

    source: Path
    """The source path on the host."""

    target: Path
    """The target path in the container."""

    read_only: bool
    """Whether the mount is read-only (default: `True`)."""

    selinux: Literal["private", "shared"] | None
    """How and whether to relabel the mount for SELinux."""

    cmdline_key = "mount"

    @property
    def cmdline_value(self) -> str:  # pyright: ignore[reportImplicitOverride]
        options = [
            f"type={self.type}",
            f"target={self.target.absolute()}",
            "ro" if self.read_only else "rw",
        ]

        if self.selinux is not None:
            options.append(f"relabel={self.selinux}")

        if self.from_ is not None:
            options += [
                f"from={self.from_[0]}",
                f"source={self.source.relative_to(self.from_[1])}",
            ]
        else:
            options.append(f"source={self.source.absolute()}")

        return ",".join(options)


@dataclass(kw_only=True, slots=True, frozen=True)
class _MountConfig:
    """The configuration for a mount."""

    name: str | None = None
    """The name of the mount (optional)."""

    category: str | None = None
    """The category of the mount (optional)."""

    type: Literal["cache", "read-only"]
    """The type of the mount.

    `cache` mounts are read-write and automatically relabel their contents for
    SELinux, while `read-only` mounts are read-only and do not relabel their
    contents.
    """

    host_path: Path
    """The path on the host."""

    container_path: Path
    """The path in the container."""

    def __post_init__(self) -> None:
        """Make sure that the paths are `Path` objects."""

        object.__setattr__(
            self, "host_path", Path(self.host_path).expanduser().absolute()
        )
        object.__setattr__(
            self,
            "container_path",
            Path(self.container_path).expanduser().absolute(),
        )

    def to_option(self, func: _BuildContextFunction) -> _RunMountOption:
        """Converts the mount configuration to a `--mount` option."""

        return _RunMountOption(
            from_=func(self.host_path),
            source=self.host_path,
            target=self.container_path,
            read_only=self.type == "read-only",
            selinux="shared" if self.type == "cache" else None,
        )

    replace: ClassVar[Final] = dataclass_replace


@dataclass(kw_only=True, frozen=True)
class BuildConfig:
    """The build configuration."""

    mounts: tuple[_MountConfig, ...]
    """The mounts to use for the build."""

    tag_domain: str
    """The domain to use for the image tag."""

    registry: str
    """The domain of the registry to push the image to."""

    sigstore_path: Path
    """The path to the Sigstore configuration file."""

    git_directory: Path
    """The path to the Git repository."""

    filesystem_to_git_prefix: Path
    """The prefix to strip from the Containerfile path in the local file system
    to get its path in the Git repository."""

    containers_policy: str
    """The contents of the `/etc/containers/policy.json` file needed to use this
    container."""

    distributor: str
    """The name of the person or organization that distributes the image."""

    # Required for `cached_property` to work with frozen dataclasses.
    __slots__: ClassVar[Final] = ("__dict__", "mounts")

    @classmethod
    def from_path(cls, path: Path) -> Self:
        """Loads the build configuration from a TOML file.

        Arguments:
            path: The path to the TOML file.

        Returns:
            The build configuration.
        """

        # Read the TOML file.
        with path.open("rb") as file:
            data = toml_load(file)

        # Convert the data.
        for i, mount in enumerate(mounts := data.get("mounts", [])):
            mounts[i] = _MountConfig(**mount)
        data["mounts"] = tuple(mounts)

        for path_key in (
            "sigstore_path",
            "git_directory",
            "filesystem_to_git_prefix",
        ):
            try:
                path_value = Path(data[path_key]).expanduser().absolute()
                if not path_value.exists():
                    raise ValueError(f"Path does not exist: {path_value}")
            except (KeyError, RuntimeError, ValueError) as e:
                raise ValueError(f"Invalid build configuration: {e}") from e
            else:
                data[path_key] = path_value

        # Return the parsed build configuration.
        try:
            return cls(**data)
        except TypeError as e:
            raise ValueError(f"Invalid build configuration: {e}") from e

    @cached_property
    def mounts_by_name(self) -> frozendict[str, _MountConfig]:
        """A dictionary of mounts by name."""

        mounts_by_name: dict[str, _MountConfig] = {}
        for mount in self.mounts:
            if mount.name is not None:
                if mount.name in mounts_by_name:
                    raise ValueError(f"Duplicate mount name: {mount.name}")
                mounts_by_name[mount.name] = mount
        return frozendict(mounts_by_name)

    @cached_property
    def mounts_by_category(self) -> frozendict[str, tuple[_MountConfig, ...]]:
        """A dictionary of mounts by category."""

        mounts_by_category: dict[str, list[_MountConfig]] = {}
        for mount in self.mounts:
            if mount.category is not None:
                mounts_by_category.setdefault(mount.category, []).append(mount)
        return frozendict({
            category: tuple(mounts)
            for category, mounts in mounts_by_category.items()
        })


@dataclass(kw_only=True, slots=True, frozen=True)
class _GitCommit:
    """The metadata for a Git commit."""

    repo_url: str
    """The URL of the Git repository."""

    hash: str
    """The hash of the Git commit."""

    date: datetime
    """The date of the Git commit."""

    author_name: str
    """The name of the author of the Git commit."""

    author_email: str
    """The email of the author of the Git commit."""

    count: int
    """The number of previous commits."""

    @classmethod
    def from_git(cls, git_directory: Path) -> Self:
        """Gets the metadata for the latest Git commit.

        Arguments:
            git_directory: The path to the Git repository.

        Returns:
            The metadata for the latest Git commit.
        """

        # Validate the arguments.
        result: dict[str, str | int | datetime] = {}

        if (
            git_directory.suffix or git_directory.stem
        ) != ".git" or not git_directory.is_dir():
            raise ValueError(f"Invalid Git directory: {git_directory}")

        # Get the repository URL.
        result["repo_url"] = subprocess_run(
            [
                "git",
                "-c",
                "safe.directory=*",
                "-C",
                git_directory.as_posix(),
                "remote",
                "get-url",
                "origin",
            ],
            check=True,
            capture_output=True,
            text=True,
        ).stdout.strip()

        # Parse the latest commit.
        output = (
            subprocess_run(
                [
                    "git",
                    "-c",
                    "safe.directory=*",
                    "-C",
                    git_directory.as_posix(),
                    "show",
                    "@",
                    "--no-patch",
                    "--format=%H%n%aI%n%aN%n%cE%n%(describe:tags=true,abbrev=1,match=root)",
                ],
                check=True,
                capture_output=True,
                text=True,
            )
            .stdout.strip()
            .splitlines()
        )

        if len(output) != 5:
            raise ValueError(
                f"Invalid Git commit output: {output} (expected 5 lines)"
            )

        result["hash"] = output[0]
        result["date"] = datetime.fromisoformat(output[1])
        result["author_name"] = output[2]
        result["author_email"] = output[3]
        result["count"] = int(output[4].split("-")[-2])

        return cls(**result)  # pyright: ignore[reportArgumentType]


@dataclass(slots=True, init=False)
class ImageMetadata:
    """The metadata for a container image."""

    image_reference: str | None = None
    """The image reference. Example: `docker.io/library/ubuntu:latest`."""

    image_name: str | None = None
    """The human-friendly name of the image."""

    image_description: str | None = None
    """The human-friendly description of the image."""

    build_date: datetime = dataclass_field(
        default_factory=lambda: datetime.now(UTC)
    )
    """The date the image was built."""

    commit: _GitCommit | None = None
    """The Git commit used to build the image."""

    restrict_capabilities: list[str] | None = None
    """Only allow the listed capabilities, or `None` to allow all."""

    distributor: str | None = None
    """The name of the person or organization that distributes the image."""

    containerfile_path: str | None = None
    """The path to the Containerfile, relative to the Git repository root."""

    architecture: str = platform_machine()
    """The architecture of the container image."""

    containers_policy: str | None = None
    """The contents of the `/etc/containers/policy.json` file."""

    def to_options(self) -> set[CmdlineOptionBase]:
        """Converts the metadata to a set of command-line options for Podman."""

        out: set[CmdlineOptionBase] = set()

        # First, handle the standard `org.opencontainers.image` labels
        #     https://github.com/opencontainers/image-spec/blob/main/annotations.md#pre-defined-annotation-keys
        assert self.commit
        opencontainers_labels = {
            "created": self.build_date.isoformat(timespec="seconds"),
            "authors": self.distributor,
            "source": self.commit.repo_url,
            "url": self.commit.repo_url,
            "revision": self.commit.hash,
            "vendor": self.distributor,
            "title": self.image_name,
            "description": self.image_description,
        }
        for key, value in opencontainers_labels.items():
            if value is not None:
                # The `org.opencontainers` values should be added as both labels
                # and annotations, since it's somewhat unclear where they really
                # belong.
                out |= {
                    CmdlineOption(
                        "label", f"org.opencontainers.image.{key}={value}"
                    ),
                    CmdlineOption(
                        "annotation", f"org.opencontainers.image.{key}={value}"
                    ),
                }

        # Save the image reference.
        if self.image_reference is not None:
            out |= {
                CmdlineOption(
                    "label",
                    f"org.opencontainers.image.ref.name={self.image_reference}",
                ),
                CmdlineOption(
                    "label",
                    f"name={self.image_reference}",
                ),
                CmdlineOption(
                    "annotation",
                    f"io.containerd.image.name={self.image_reference}",
                ),
            }

        # Add the non-standard `com.docker.official-images.bashbrew.arch`
        # annotation, which appears to be used by quite a few tools.
        if self.architecture is not None:
            out |= {
                CmdlineOption(
                    "annotation",
                    f"com.docker.official-images.bashbrew.arch={self.architecture}",
                )
            }

        # We don't use OpenShift, but it defines some useful labels
        #     https://github.com/openshift/openshift-docs/blob/66f2ac61/modules/builds-output-image-labels.adoc
        # so we'll add them here
        out |= {
            CmdlineOption(
                "label",
                f"io.openshift.build.commit.author={self.commit.author_name} <{self.commit.author_email}>",
            ),
            CmdlineOption(
                "label",
                f"io.openshift.build.commit.date={self.commit.date.astimezone().replace(tzinfo=None).isoformat(sep=' ', timespec='minutes')}",
            ),
            CmdlineOption(
                "label",
                f"io.openshift.build.commit.id={self.commit.hash}",
            ),
            CmdlineOption(
                "label",
                "io.openshift.build.commit.ref=master",
            ),
            CmdlineOption(
                "label",
                f"io.openshift.build.source-location={self.commit.repo_url}",
            ),
            CmdlineOption(
                "label",
                "vcs-type=git",
            ),
        }

        # Add the build system's name and version as a label:
        #     https://github.com/projectatomic/ContainerApplicationGenericLabels/blob/3e158d90/vendor/redhat/labels.md#other-labels
        out |= {
            CmdlineOption(
                "label",
                f"com.redhat.build-host={getfqdn()}",
            ),
            CmdlineOption("identity-label"),
        }

        # We don't use Hummingbird, but it also defines some useful labels
        out |= {
            CmdlineOption(
                "label",
                f"io.hummingbird-project.containerfile={self.containerfile_path}",
            )
        }

        # Add some custom annotations.
        if self.containers_policy is not None:
            out |= {
                CmdlineOption(
                    "label",
                    f"ca.maxchernoff.containers-policy-json={self.containers_policy}",
                ),
            }

        return out


#########################
### Class Definitions ###
#########################


class _Parser:
    """Parse and expand the macros."""

    _parentheses: Final[Pattern[str]] = regex(r"([\(\)])")
    _brackets: Final[Pattern[str]] = regex(r"([\[\]])")
    _command: Final[Pattern[str]] = regex(r"@(\w+)")

    @classmethod
    def _balance(
        cls, s: str, pattern: Pattern[str], level: int = 0
    ) -> Generator[str]:
        """Yields the text inside balanced parentheses in a string."""

        if len(match := pattern.split(s, maxsplit=1)) == 3:
            yield from match[:2]
            level += 1 if (sep := match[1]) in "([" else -1
            if level != 0 or sep not in ")]":
                yield from cls._balance(match[2], pattern, level)

    def expand(self, text: str) -> str:
        """Expands the macros in a string.

        Arguments:
            text: The string to expand.

        Returns:
            The expanded string.
        """

        out: list[str] = []
        while (match := self._command.search(text)) is not None:
            # Get the macro's contents
            start, end, cmd = match.start(), match.end(), match[1]

            options = (
                "".join(self._balance(text[end:], self._brackets))
                if text[end] == "["
                else ""
            )
            body = "".join(
                self._balance(text[end + len(options) :], self._parentheses)
            )

            # Update the state for the next iteration
            out.append(text[:start])
            text = text[end + len(body) + len(options) :]

            # Parse the macro
            body = body[1:-1]  # Remove the parentheses
            options_dict = {
                k: v
                for k, v in (
                    option.strip().split("=", maxsplit=1)
                    for option in options[1:-1].split(",")
                    if option.strip()
                )
            }

            # Run the macro
            if isinstance(func := getattr(self, cmd, None), MacroFunction):
                out.append(func(body, **options_dict))
            else:
                raise ValueError(f"Unknown macro: {cmd}")

        out.append(text)
        return "".join(out)


class Containerfile[Initialized: None | Never](_Parser):  # noqa: RUF020
    """Generates an executable Containerfile from a template with macros."""

    # Initialization functions
    def __init__(
        self: Containerfile[None], *, source: Path, config: BuildConfig
    ) -> None:
        """Initializes the Containerfile.

        Arguments:
            source: The path to the source (unprocessed) Containerfile.
            config: The build configuration.
        """

        # Initialize the instance variables.
        self._source_path: Path = source
        self._source_contents: str | Initialized = None
        self.__temp_dir_obj: TemporaryDirectory[str] | Initialized = None
        self._temp_dir: Path | Initialized = None
        self._podman_args: set[CmdlineOptionBase] = set()
        self._config: BuildConfig = config
        self._build_contexts: dict[Path, str] = {}

        # Initialize the metadata.
        self.metadata: ImageMetadata = ImageMetadata()
        self.metadata.containers_policy = self._config.containers_policy
        self.metadata.distributor = self._config.distributor
        self.metadata.restrict_capabilities = ["CAP_NET_BIND_SERVICE"]

    def __enter__(self: Containerfile[None]) -> Containerfile[Never]:
        """Initialize the instance."""

        # Create a temporary directory.
        if self.__temp_dir_obj is not None:
            raise RuntimeError("Already initialized.")

        self.__temp_dir_obj = TemporaryDirectory(
            delete=True,
            ignore_cleanup_errors=True,
            prefix="container-build-",
        )
        self._temp_dir = Path(self.__temp_dir_obj.name)
        self._build_context(self._temp_dir, name="temp_dir")

        # Read the source Containerfile.
        self._source_contents = self._source_path.read_text()

        # Parse the metadata from the Git repository.
        self.metadata.commit = _GitCommit.from_git(
            git_directory=self._config.git_directory
        )

        self.metadata.containerfile_path = self._source_path.relative_to(
            self._config.filesystem_to_git_prefix
        ).as_posix()

        return cast(Containerfile[Never], self)

    def __exit__(self, *args: object) -> None:
        """Cleans up the temporary directory."""

        if self.__temp_dir_obj is not None:
            self.__temp_dir_obj.cleanup()
            self.__temp_dir_obj = None  # pyright: ignore[reportAttributeAccessIssue]
            self._temp_dir = None  # pyright: ignore[reportAttributeAccessIssue]

    # Parsing functions
    @cache
    def _parse(self: Containerfile[Never]) -> Path:
        """Parse the source Containerfile.

        Returns:
            The path to the parsed Containerfile, with all macros expanded.
        """

        out_path = self._temp_file(extension="containerfile")
        with out_path.open("w") as out_file:
            out_file.write(self.expand(self._source_contents))

        return out_path

    @property
    def podman_args(self) -> frozenset[CmdlineOptionBase]:
        """The arguments to pass to Podman to use this Containerfile."""

        return frozenset(
            self._podman_args
            | {(CmdlineOption("file", self._parse().absolute().as_posix()))}
        )

    # Helper functions
    def _temp_file(
        self: Containerfile[Never],
        extension: str,
        filename: str | None = None,
    ) -> Path:
        """Returns a temporary file that is automatically cleaned up.

        Arguments:
            extension: The file extension to use for the temporary file.
            filename: The name of the temporary file (optional).

        Returns:
            The path to the temporary file.
        """

        if filename:
            return (self._temp_dir / filename).with_suffix(f".{extension}")
        else:
            with NamedTemporaryFile(
                delete=False,
                dir=self._temp_dir,
                prefix="tmp-",
                suffix=f".{extension}",
            ) as temp_file:
                return Path(temp_file.name)

    def _build_context(
        self, path: Path, name: str | None = None
    ) -> tuple[str, Path]:
        """Adds the given path to the build context.

        Arguments:
            path: The path to add to the build context.
            name: The name to use for the build context (optional).

        Returns:
            A tuple of the name and path of the build context.
        """

        # Parse the arguments.
        path = path.absolute()

        if name is None:
            name = str(path).replace("=", "-")

        # Return the previous value if the path is already in the build context.
        if path in self._build_contexts:
            return (self._build_contexts[path], path)

        # Make sure that the name is unique.
        if name in self._build_contexts.values():
            raise ValueError("Build context name must be unique.")

        # Now add the path to the build context.
        self._podman_args.add(
            CmdlineOption("build-context", f"{name}={path.absolute()}")
        )
        self._build_contexts[path] = name

        return (name, path)

    def _mount_run(
        self: Containerfile[Never],
        body: str,
    ) -> tuple[_RunMountOption, Path]:
        """Mounts a shell script to be used in a `RUN` command."""

        # Use a deterministic filename so that the Containerfile doesn't change
        # every time we build the container.
        host_script_path = self._temp_file(
            filename=shake_128(body.encode()).hexdigest(
                _HASH_DIGEST_LENGTH // 2
            ),
            extension="sh",
        )

        # Create a temporary shell script with the body of the macro
        with host_script_path.open("w") as script_file:
            script_file.write(
                dedent(f"""
                    #!/bin/sh
                    set -euxo pipefail
                    export SOURCE_DATE_EPOCH=0
                    export SYSTEMD_OFFLINE=1 SYSTEMD_IN_CHROOT=1
                    {body}
                """)
            )
        host_script_path.chmod(_SCRIPT_PERMISSIONS)

        # Run the shell script in the container.
        container_script_path = Path(f"run/scripts/{host_script_path.name}")
        mount_arg = _RunMountOption(
            from_=self._build_context(host_script_path.parent),
            source=host_script_path,
            target=container_script_path,
            read_only=True,
            selinux="private",
        )
        return mount_arg, Path("/") / container_script_path

    # Macro functions
    def run(
        self: Containerfile[Never],
        body: str,
        mounts: str | None = None,
    ) -> str:
        """Run a shell command.

        We use this macro instead of using `RUN` directly because this lets us
        write multi-line shell commands without having to escape the newlines.

        Arguments:
            body: The shell command to run.

            mounts: The categories of mounts to use for the duration of this
                command (optional). Mounts are separated by space characters.

        Returns:
            The `RUN` command to use in the Containerfile.
        """

        # Parse the arguments.
        cmd: list[str | CmdlineOptionBase] = ["RUN"]

        # Add the mounts to the command.
        if mounts is not None:
            for category in mounts.split():
                try:
                    for mount in self._config.mounts_by_category[category]:
                        cmd.append(mount.to_option(self._build_context))
                except KeyError:
                    raise ValueError(f"Unknown mount category: {category}")

        # Run the command in the container.
        script_mount_arg, script_path = self._mount_run(body)
        cmd += [script_mount_arg, script_path.as_posix()]

        return " ".join(CmdlineOptionBase.convert(cmd))

    def dnf_install(
        self: Containerfile[Never],
        body: str,
        install_root: str | None = None,
        documentation: str = "false",  # pyright: ignore[reportRedeclaration]
    ) -> str:
        """Install packages using DNF.

        Arguments:
            body: The list of packages to install. Packages are separated by
                whitespace, and comments can be added using `#`.

            install_root: The root directory to install the packages to
                (optional).

            documentation: Whether to install documentation files (default:
                `False`).

        Returns:
            The `RUN` command to use in the Containerfile.
        """

        # Parse the arguments.
        cmd: list[str | CmdlineOptionBase] = ["RUN"]

        documentation: bool
        if documentation.casefold() == "true":
            documentation = True
        elif documentation.casefold() == "false":
            documentation = False
        else:
            raise ValueError(
                f"Invalid value for documentation: {documentation}."
            )

        # Link the DNF cache directory to the container
        try:
            dnf_cache = self._config.mounts_by_name["dnf"]
        except KeyError:
            raise ValueError(
                "The build configuration must contain a mount named 'dnf'."
            )
        dnf_cache.host_path.mkdir(parents=True, exist_ok=True)

        cmd.append(dnf_cache.to_option(self._build_context))

        if install_root is not None:
            cmd.append(
                dnf_cache.replace(
                    container_path=Path(install_root) / "var/cache/libdnf5/"
                ).to_option(self._build_context)
            )

        # Get the list of packages
        packages = shlex_split(body, comments=True)

        # Generate the install script
        script_arg, script_path = self._mount_run(
            " \\\n".join([
                # We need to use the loop in here because if we're building
                # multiple containers at the same time, DNF may fail to lock the
                # cache database.
                "for _ in $(seq 3); do",
                "    dnf install",
                "    --assumeyes",
                "    --no-docs" if not documentation else "",
                f"   --installroot={install_root}" if install_root else "",
                '    --setopt="install_weak_deps=false"',
                '    --setopt="keepcache=true"',
                "    --use-host-config",
                *packages,
                "    && break",
                "    || sleep $((30 + RANDOM % 90));",
                "done;",
                f"rm -rf {install_root or ''}/var/{{log,lib}}/dnf*;",
            ])
        )
        cmd += [script_arg, script_path.as_posix()]

        # Generate the final command
        result: list[str] = []

        if install_root is not None:
            result.append(f"RUN mkdir -p {install_root}/var/cache/")

        result.append(" ".join(CmdlineOptionBase.convert(cmd)))
        return "\n\n".join(result)

    def rpm_erase_all_except(
        self: Containerfile[Never],
        body: str,
        install_root: str | None = None,
    ) -> str:
        """Erase all RPM packages (incl. dependencies) except those listed.

        Arguments:
            body: The list of packages to keep. Packages are separated by
                whitespace, and comments can be added using `#`.

            install_root: The root directory to erase the packages from
                (optional).

        Returns:
            The `RUN` command to use in the Containerfile.
        """

        packages = shlex_split(body, comments=True)
        mount_arg, container_script_path = self._mount_run(
            " ".join([
                "rpm",
                f"--root={install_root or '/'}",
                "--nodeps",
                "--erase",
                "$(",
                "    rpm",
                f"   --root={install_root or '/'}",
                "    --query",
                "    --all",
                "    |",
                "    grep",
                "    --extended-regexp",
                "    --invert-match",
                f"   '^({'|'.join(packages)})'",
                ")",
            ])
        )
        return " ".join(
            CmdlineOptionBase.convert([
                "RUN",
                mount_arg,
                container_script_path.as_posix(),
            ])
        )

    def with_commit_info(self: Containerfile[Never], body: str) -> str:
        """Adds a ${COMMIT_INFO} environment variable to the container."""

        if body.strip():
            raise ValueError("The body of the macro must be empty.")

        if not self.metadata.commit:
            raise ValueError("The commit metadata is not set.")

        return "".join([
            "ARG ",
            'COMMIT_INFO="',
            self.metadata.commit.date
            .astimezone()
            .replace(tzinfo=None)
            .isoformat(sep=" ", timespec="minutes"),
            f" ({self.metadata.commit.count:>4d}+{self.metadata.commit.hash[:8]})",
            '"',
        ])

    def allow_all_capabilities(self: Containerfile[Never], body: str) -> str:
        """Allows all capabilities in the container."""

        if body.strip():
            raise ValueError("The body of the macro must be empty.")

        self.metadata.restrict_capabilities = None

        return ""

    def set_layer(
        self: Containerfile[Never],
        body: str,
        layer_name: str,
        update_frequency: str = _UpdateFrequency.weekly,  # pyright: ignore[reportRedeclaration]
        filter_rpm: str = "true",  # pyright: ignore[reportRedeclaration]
    ) -> str:
        """Sets the image layer for the specified globs.

        Arguments:
            body: The list of globs to set the layer for. Globs are separated by
                whitespace, and comments can be added using `#`.

            layer_name: The name of the layer to set.

            update_frequency: The frequency at which the contents of the layer
                typically change (default: `weekly`).

            filter_rpm: Whether to exclude files managed by RPM from the layer
                (default: `True`).

        Returns:
            The `RUN` command to use in the Containerfile.
        """

        # Parse the arguments.
        update_frequency: _UpdateFrequency = _UpdateFrequency(update_frequency)

        filter_rpm: bool
        if filter_rpm.casefold() == "true":
            filter_rpm = True
        elif filter_rpm.casefold() == "false":
            filter_rpm = False
        else:
            raise ValueError(f"Invalid value for filter_rpm: {filter_rpm}.")

        # Initialize the command variables.
        inner_cmd: list[str] = []
        cmd: list[str | CmdlineOptionBase] = ["RUN"]

        # Copy `busybox` to the temporary directory so that we can mount it into
        # the container.
        system_busybox = Path("/usr/bin/busybox")
        container_busybox = Path("/run/scripts/busybox")
        user_busybox = self._temp_dir / "busybox"

        if not user_busybox.is_file():
            system_busybox.copy_into(self._temp_dir)
            user_busybox.chmod(0o555)

        # Add `busybox` to the container to ensure that all the needed commands
        # are available.
        cmd.append(
            _RunMountOption(
                from_=self._build_context(user_busybox.parent),
                source=user_busybox,
                target=container_busybox,
                read_only=True,
                selinux="private",
            )
        )

        # `chunkah` handles splitting the RPM files itself, so we shouldn't mark
        # them as belonging to one of our own layers.
        if filter_rpm:
            inner_cmd.append(
                "rpm --query --list --all | sort > /tmp/rpm-files.txt"
            )
        else:
            inner_cmd.append("touch /tmp/rpm-files.txt")

        # Find all files matched by the provided globs.
        inner_cmd.append(
            " ".join([
                f"{container_busybox} find",
                "/",
                r"-not \( \(",
                " -o ".join(f"-path '{path}'" for path in _LAYER_SKIP_PATHS),
                r"\) -prune \)",
                "-not -type l",
                r"\(",
                " -o ".join(
                    f"-path '{glob}'"
                    for glob in shlex_split(body, comments=True)
                ),
                r"\)",
                "-print",
                "|",
                f"{container_busybox} sort",
                "> /tmp/layer-files.txt",
            ])
        )

        # Set the xattrs for the files to assign them to the specified layer.
        inner_cmd.append(
            " ".join([
                f"{container_busybox} comm",
                "-13",
                "/tmp/rpm-files.txt",
                "/tmp/layer-files.txt",
                "|",
                f"{container_busybox} tr",
                r"'\n' '\0'",
                "|",
                f"{container_busybox} xargs",
                "-0",
                "-r",
                "-P 4",
                f"{container_busybox} setfattr",
                "-h",
                "-n user.component",
                f"-v {layer_name}",
                "-n user.update-interval",
                f"-v {update_frequency}",
            ])
        )

        # Run the command in the container.
        script_mount_arg, container_script_path = self._mount_run(
            "\n".join(inner_cmd)
        )
        cmd += [script_mount_arg, container_script_path.as_posix()]

        return " ".join(CmdlineOptionBase.convert(cmd))


############################
### Function Definitions ###
############################


def build(source_dir: Path, config: BuildConfig, tag: str) -> None:
    """Builds a Podman container image.

    Arguments:
        source_dir: The directory containing the Containerfile.
        config: The build configuration.
        tag: The tag to apply to the built image.
    """

    # Validate the arguments.
    in_path = source_dir / "Containerfile"
    if not in_path.is_file():
        raise FileNotFoundError(f'"Containerfile" not found in {source_dir}')

    # Build the container image.
    with Containerfile(source=in_path, config=config) as containerfile:
        containerfile.metadata.image_reference = f"{config.registry}/{tag}"
        args = containerfile.podman_args | {
            CmdlineOption("format", "oci"),
            CmdlineOption("no-cache"),
            CmdlineOption("pull", "always"),
            CmdlineOption("rewrite-timestamp"),
            CmdlineOption("security-opt", "label=role:user_r"),
            CmdlineOption("security-opt", "label=user:user_u"),
            CmdlineOption("squash"),
            CmdlineOption("tag", f"{config.tag_domain}/{tag}"),
            CmdlineOption("timestamp", "0"),
        }
        subprocess_run(
            [
                "podman",
                "build",
                *CmdlineOptionBase.convert(args),
                source_dir.absolute(),
            ],
            check=True,
        )

    # Create the FIFO for the container image.
    temp_dir = TemporaryDirectory(dir="/var/tmp", prefix="container-build-")
    fifo = Path(temp_dir.name) / "container.tar"
    mkfifo(fifo, 0o600)

    # Rechunk the container image.
    with (
        Popen(
            [
                "podman",
                "run",
                *CmdlineOptionBase.convert(
                    CmdlineOption("rm"),
                    CmdlineOption("pull", "newer"),
                    CmdlineOption("userns", "host"),
                    CmdlineOption("env", "SOURCE_DATE_EPOCH=0"),
                    CmdlineOption(
                        "mount",
                        ",".join([
                            "type=image",
                            f"source=containers-storage:{config.tag_domain}/{tag}",
                            "target=/chunkah",
                        ]),
                    ),
                    CmdlineOption(
                        "volume",
                        f"{fifo.absolute()}:/run/container.tar:rw,Z,U",
                    ),
                ),
                "docker://quay.io/coreos/chunkah:latest",
                "build",
                *CmdlineOptionBase.convert(
                    CmdlineOption("tag", f"{config.tag_domain}/{tag}"),
                    CmdlineOption("source-date-epoch", "0"),
                    *(
                        CmdlineOption("prune", path)
                        for path in (
                            "/boot/",
                            "/dev/",
                            "/proc/",
                            "/run/",
                            "/sys/",
                            "/sysroot/",
                            "/tmp/",
                            "/var/cache/",
                            "/var/log/",
                            "/var/tmp/",
                        )
                    ),
                    CmdlineOption("max-layers", "200"),
                    CmdlineOption(
                        "config-str",
                        subprocess_run(
                            [
                                "podman",
                                "inspect",
                                f"containers-storage:{config.tag_domain}/{tag}",
                            ],
                            check=True,
                            text=True,
                            stdout=PIPE,
                        ).stdout.strip(),
                    ),
                    CmdlineOption("output", "oci-archive:/run/container.tar"),
                ),
            ],
        ) as chunkah,
        Popen(
            [
                "skopeo",
                "copy",
                *CmdlineOptionBase.convert(
                    CmdlineOption("all"),
                    CmdlineOption("dest-compress-format", "zstd:chunked"),
                    CmdlineOption("dest-compress-level", "15"),
                    CmdlineOption("dest-force-compress-format"),
                    CmdlineOption("dest-precompute-digests"),
                    CmdlineOption("dest-tls-verify", "false"),
                    CmdlineOption("format", "oci"),
                    CmdlineOption("image-parallel-copies", "8"),
                    CmdlineOption("created-annotation", "false"),
                    CmdlineOption(
                        "sign-by-sigstore", config.sigstore_path.as_posix()
                    ),
                    CmdlineOption(
                        "sign-identity", f"{config.tag_domain}/{tag}"
                    ),
                ),
                f"oci-archive:{fifo.absolute()}",
                f"docker://{config.registry}/{tag}",
            ],
        ) as skopeo,
    ):
        if chunkah.wait() != 0:
            raise CalledProcessError(chunkah.returncode, chunkah.args)

        if skopeo.wait() != 0:
            raise CalledProcessError(skopeo.returncode, skopeo.args)


###################
### Entry Point ###
###################


def main() -> int:
    """The main entry point for the script."""

    # Define the command-line arguments.
    parser = ArgumentParser(
        description=__doc__,
        formatter_class=ArgumentDefaultsHelpFormatter,
    )

    parser.add_argument(
        "--directory",
        type=Path,
        required=True,
        help="The directory containing the Containerfile.",
    )
    parser.add_argument(
        "--config",
        type=Path,
        required=True,
        help="The path to the configuration file.",
    )
    parser.add_argument(
        "--tag",
        type=str,
        required=True,
        help="The tag to apply to the built image.",
    )

    # Parse the command-line arguments.
    args = parser.parse_args()
    directory = cast(Path, args.directory)
    config_path = cast(Path, args.config)
    tag = cast(str, args.tag)

    if not directory.is_dir():
        parser.error(f'"{directory}" is not a directory.')

    if ":" not in tag:
        parser.error(f'"{tag}" is not a valid tag (must contain a colon).')

    # Build the container image using Podman.
    build(
        source_dir=directory,
        config=BuildConfig.from_path(config_path),
        tag=tag,
    )

    return 0


if __name__ == "__main__":
    exit(main())
